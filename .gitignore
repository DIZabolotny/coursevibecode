# Ignore everything
*

# Keep tracked essentials
!.gitignore
!README.md
!CLAUDE.md
!AGENTS.md
!manifest.md

# Keep courses directory (all content)
!courses/
!courses/**

# Keep framework
!.framework/
!.framework/**

# Keep Claude config (selective)
!.claude/
!.claude/SNAPSHOT.md
!.claude/BACKLOG.md
!.claude/ARCHITECTURE.md
!.claude/ROADMAP.md
!.claude/IDEAS.md
!.claude/SESSION-HANDOFF.md
!.claude/rules/
!.claude/rules/*.md

# Always ignore
.DS_Store
.claude/settings.local.json
.production-credentials
.env
.env.*
*credentials*
*.pem
*.key
.claude/.last_session
.claude/.session-owner
.claude/logs/
reports/
